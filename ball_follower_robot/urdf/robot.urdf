<?xml version="1.0"?>
<robot name="ball_follower_robot">

  <!--
    Ball Follower Robot URDF
    
    Actual dimensions:
      Chassis:  15 cm (length/X) x 19 cm (breadth/Y) x 8 cm (height/Z)
      Wheels:   5.5 cm diameter (2.75 cm radius), ~2.5 cm wide
    
    Layout (top view):
      FRONT → caster wheel + servo + ultrasonic sensor
      BACK  → 2 drive wheels (left + right)
  -->

  <!-- ==================== BASE FOOTPRINT ==================== -->
  <link name="base_footprint"/>

  <!-- Chassis sits on top of drive wheels (wheel radius = 0.0275m) -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.0275" rpy="0 0 0"/>
  </joint>

  <!-- ==================== BASE LINK (Chassis) ==================== -->
  <!-- 15cm x 19cm x 8cm box -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.15 0.19 0.08"/>
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.15 0.3 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.19 0.08"/>
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <inertia ixx="0.0029" ixy="0" ixz="0"
               iyy="0.0020" iyz="0"
               izz="0.0039"/>
    </inertial>
  </link>

  <!-- Gazebo chassis material -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- ==================== LEFT WHEEL (BACK-LEFT) ==================== -->
  <!-- Diameter 5.5cm = radius 0.0275m, width ~2.5cm -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0275" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.0275" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.00003" ixy="0" ixz="0"
               iyy="0.00003" iyz="0"
               izz="0.00005"/>
    </inertial>
  </link>

  <!-- Wheels at the BACK: X = -0.045 (toward rear), Y = ±0.1075 (half breadth + half wheel width) -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.045 0.1075 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ==================== RIGHT WHEEL (BACK-RIGHT) ==================== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0275" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.0275" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.00003" ixy="0" ixz="0"
               iyy="0.00003" iyz="0"
               izz="0.00005"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.045 -0.1075 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ==================== FRONT CASTER WHEEL ==================== -->
  <!-- Small caster at the FRONT of the robot -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.0125"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <!-- Caster at front: X = +0.06 (toward front), drops below chassis -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.06 0 -0.015" rpy="0 0 0"/>
  </joint>

  <gazebo reference="caster_wheel">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ==================== SERVO MOUNT (FRONT) ==================== -->
  <!-- Servo sits on top of chassis at the front -->
  <link name="servo_link">
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000005" ixy="0" ixz="0"
               iyy="0.000005" iyz="0"
               izz="0.000005"/>
    </inertial>
  </link>

  <!-- Servo at front of chassis, on top -->
  <joint name="servo_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="servo_link"/>
    <origin xyz="0.05 0 0.0925" rpy="0 0 0"/>
  </joint>

  <gazebo reference="servo_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ==================== ULTRASONIC SENSOR (on servo) ==================== -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <box size="0.045 0.02 0.015"/>
      </geometry>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <material name="silver">
        <color rgba="0.7 0.7 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.045 0.02 0.015"/>
      </geometry>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <!-- Revolute joint: servo rotates sensor left/right (-90° to +90°) -->
  <joint name="servo_joint" type="revolute">
    <parent link="servo_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.0" velocity="2.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <gazebo reference="laser_frame">
    <material>Gazebo/White</material>
  </gazebo>

  <!-- ==================== USB CAMERA (FRONT) ==================== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.025 0.05 0.025"/>
      </geometry>
      <material name="dark">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.05 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000005" ixy="0" ixz="0"
               iyy="0.000005" iyz="0"
               izz="0.000005"/>
    </inertial>
  </link>

  <!-- Camera at front, on top of chassis -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.065 0 0.0925" rpy="0 0 0"/>
  </joint>

  <!-- Camera optical frame (ROS convention: Z forward, X right, Y down) -->
  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <gazebo reference="camera_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- ==================== GAZEBO HARMONIC PLUGINS ==================== -->
  <gazebo>
    <!-- Diff Drive Controller -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.215</wheel_separation>
      <wheel_radius>0.0275</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <min_linear_acceleration>-1.0</min_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <min_angular_acceleration>-2.0</min_angular_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>

    <!-- Joint State Publisher (publishes joint positions to /world/default/model/ball_follower_robot/joint_state) -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>servo_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
